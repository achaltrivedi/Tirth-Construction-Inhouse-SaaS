generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("operator") // "admin" or "operator"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]

  @@index([createdAt])
}

model Site {
  id            String   @id @default(cuid())
  name          String
  clientName    String
  projectType   String
  contractValue String?
  startDate     DateTime
  status        String   @default("active") // "active", "completed", "on-hold"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions Transaction[]
  workers      Worker[]
  attendances  Attendance[]

  @@index([status])
  @@index([createdAt])
}

model Transaction {
  id          String    @id @default(cuid())
  siteId      String
  date        DateTime
  description String    @db.Text
  cashIn      Float     @default(0)
  cashOut     Float     @default(0)
  netValue    Float     @default(0)
  addedBy     String?   // User display name who created this entry
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site      Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([siteId])
  @@index([date])
  @@index([siteId, date])
  @@index([isDeleted])
  @@index([createdAt])
}

model Worker {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  siteId    String?
  wage      Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site       Site?        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  attendance Attendance[]
  deductions Deduction[]

  @@index([siteId])
  @@index([isActive])
  @@index([createdAt])
}

model Attendance {
  id        String   @id @default(cuid())
  workerId  String
  siteId    String
  date      DateTime
  status    String   // "present", "absent", "half-day"
  notes     String?  @db.Text
  markedBy  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([workerId, date])
  @@index([workerId])
  @@index([siteId])
  @@index([date])
  @@index([createdAt])
}

model Deduction {
  id        String   @id @default(cuid())
  workerId  String
  date      DateTime
  amount    Float
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([date])
  @@index([workerId, date])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  transactionId String?
  action        String   // "create", "update", "delete"
  oldValue      String?  @db.Text // JSON string of old values
  newValue      String?  @db.Text // JSON string of new values
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([userId])
  @@index([createdAt])
}
